          <mxGeometry x="60" y="450" width="60" height="60" as="geometry"/>
        </mxCell>

        <!-- RESOURCE GROUP -->
        <mxCell id="rg" value="&lt;b&gt;rg-prd-tk-paas-cin-001&lt;/b&gt;  —  Central India" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#0078D4;dashed=1;dashPattern=6 3;verticalAlign=top;align=left;spacingLeft=10;spacingTop=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="200" y="110" width="1500" height="840" as="geometry"/>
        </mxCell>

        <!-- APP SERVICE PLAN -->
        <mxCell id="asp" value="&lt;b&gt;asp-prd-tk-cin-001&lt;/b&gt;  ·  App Service Plan · Windows · B1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFF6FF;strokeColor=#0078D4;verticalAlign=top;align=left;spacingLeft=36;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="230" y="150" width="850" height="660" as="geometry"/>
        </mxCell>
        <mxCell id="asp-icon" value="" style="shape=image;image=img/lib/azure2/compute/App_Service_Plans.svg;html=1;" vertex="1" parent="1">
          <mxGeometry x="238" y="153" width="28" height="24" as="geometry"/>
        </mxCell>

        <!-- WEB APP FRONTEND -->
        <mxCell id="fend" value="&lt;b&gt;app-prd-tk-fend-cin-sm001&lt;/b&gt;  ·  Frontend (SPA)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#059669;verticalAlign=top;align=left;spacingLeft=10;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="255" y="210" width="380" height="580" as="geometry"/>
        </mxCell>
        <mxCell id="fend-icon" value="" style="shape=image;image=img/lib/azure2/compute/App_Services.svg;html=1;" vertex="1" parent="1">
          <mxGeometry x="410" y="250" width="55" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="fend-detail" value="&lt;b&gt;Runtime:&lt;/b&gt; Node 20 LTS / Windows IIS&lt;br&gt;&lt;b&gt;HTTPS Only:&lt;/b&gt; On · TLS 1.2+&lt;br&gt;&lt;br&gt;&lt;b&gt;Deploy:&lt;/b&gt; zip deploy (OneDeploy)&lt;br&gt;• index.html + assets (React SPA)&lt;br&gt;• web.config (URL Rewrite)&lt;br&gt;• applicationHost.xdt (ARR proxy)&lt;br&gt;&lt;br&gt;&lt;b&gt;URL Rewrite:&lt;/b&gt;&lt;br&gt;/api/* → backend Web App&lt;br&gt;/* → index.html (SPA routing)&lt;br&gt;&lt;br&gt;&lt;b&gt;Domínio customizado:&lt;/b&gt;&lt;br&gt;copaazure2026.silasmachado.cloud&lt;br&gt;&lt;br&gt;&lt;b&gt;Certificado:&lt;/b&gt; Gerenciado&lt;br&gt;(GeoTrust / App Service Free Cert)&lt;br&gt;&lt;br&gt;&lt;b&gt;applicationHost.xdt:&lt;/b&gt;&lt;br&gt;Habilita ARR proxy no IIS&lt;br&gt;(equivalente ao &quot;Enable proxy&quot;&lt;br&gt;da VM — necessário para&lt;br&gt;URL Rewrite para URL externa)" style="text;html=1;align=left;verticalAlign=top;fontSize=9;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="260" y="325" width="368" height="450" as="geometry"/>
        </mxCell>

        <!-- WEB APP BACKEND -->
        <mxCell id="bend" value="&lt;b&gt;app-prd-tk-bend-cin-sm001&lt;/b&gt;  ·  Backend API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;verticalAlign=top;align=left;spacingLeft=10;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="660" y="210" width="400" height="580" as="geometry"/>
        </mxCell>
        <mxCell id="bend-icon" value="" style="shape=image;image=img/lib/azure2/compute/App_Services.svg;html=1;" vertex="1" parent="1">
          <mxGeometry x="815" y="250" width="55" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="bend-detail" value="&lt;b&gt;Runtime:&lt;/b&gt; Node 20 LTS / Windows IIS&lt;br&gt;&lt;b&gt;HTTPS Only:&lt;/b&gt; On · TLS 1.2+&lt;br&gt;&lt;br&gt;&lt;b&gt;Deploy:&lt;/b&gt; zip deploy (OneDeploy)&lt;br&gt;• web.config (iisnode handler)&lt;br&gt;• src/ (Express API)&lt;br&gt;• node_modules/ (prod deps)&lt;br&gt;&lt;br&gt;&lt;b&gt;App Settings:&lt;/b&gt;&lt;br&gt;• JWT_SECRET&lt;br&gt;• JWT_EXPIRES_IN = 7d&lt;br&gt;• FRONTEND_URL = *&lt;br&gt;• DB_SERVER · DB_PORT&lt;br&gt;• DB_NAME · DB_USER · DB_PASSWORD&lt;br&gt;&lt;br&gt;&lt;b&gt;Connection String:&lt;/b&gt;&lt;br&gt;DefaultConnection (SQLAzure)&lt;br&gt;&lt;br&gt;&lt;b&gt;VNet Integration:&lt;/b&gt;&lt;br&gt;→ snet-prd-appsvc-cin-001&lt;br&gt;→ Tráfego ao SQL via Private Endpoint&lt;br&gt;(banco nunca exposto à Internet)" style="text;html=1;align=left;verticalAlign=top;fontSize=9;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="665" y="325" width="388" height="450" as="geometry"/>
        </mxCell>

