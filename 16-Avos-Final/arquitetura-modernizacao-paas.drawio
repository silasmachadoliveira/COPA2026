<mxfile host="app.diagrams.net" version="24.0.0">
  <diagram id="modernizacao-paas" name="Modernização VM → PaaS">
    <mxGraphModel dx="1800" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="1">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />

        <!-- TÍTULO -->
        <mxCell id="title" value="&lt;font style=&quot;font-size:20px&quot;&gt;&lt;b&gt;Copa do Mundo Azure 2026 — FIFA 2026 Tickets&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px;color:#6B7280&quot;&gt;Modernização VM → PaaS  ·  App Service + Azure SQL Database  ·  Central India  ·  16-Avos-Final&lt;/font&gt;" style="text;html=1;align=center;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="900" height="55" as="geometry"/>
        </mxCell>

        <!-- INTERNET -->
        <mxCell id="internet" value="&lt;b&gt;Internet&lt;/b&gt;&lt;br&gt;Torcedor" style="shape=image;image=img/lib/azure2/networking/CDN_Profiles.svg;html=1;align=center;verticalLabelPosition=bottom;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="250" width="60" height="60" as="geometry"/>
        </mxCell>

        <!-- DNS ZONE -->
