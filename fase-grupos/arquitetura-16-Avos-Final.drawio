<mxCell id="flow" value="<b>Fluxo da Aplicação</b><br><br>Usuários → DNS (CNAME) → Frontend Web App (HTTPS 443) → Backend Web App (ARR Proxy/HTTPS) → VNet Integration (Rede Privada) → Private Endpoint (Subnet PE) → Azure SQL Database (TCP 1433 Privado)" style="text;html=1;align=left;verticalAlign=top;fontSize=9;fillColor=none;strokeColor=none;rounded=1;strokeColor=#94A3B8;fillColor=#F8FAFC;" vertex="1" parent="1"><mxGeometry x="520" y="880" width="960" height="80" as="geometry"/></mxCell>
