<mxCell id="info" value="<b>Informações Principais</b><br><br>• Região: Central India<br>• Frontend: Node 20 + React (SPA)<br>• Backend: Node 20 + Express (API)<br>• Banco: Azure SQL Database (Basic)<br>• Conectividade: Private Endpoint<br>• DNS: Private DNS Zone<br>• Certificado: App Service Managed (HTTPS)<br>• Backend com VNet Integration<br>• Frontend sem VNet Integration" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;fontSize=10;fillColor=#F8FAFC;strokeColor=#334155;" vertex="1" parent="1"><mxGeometry x="1280" y="110" width="380" height="240" as="geometry"/></mxCell>
