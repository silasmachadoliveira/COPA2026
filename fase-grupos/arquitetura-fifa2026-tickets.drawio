              <mxPoint x="718" y="580" />
              <mxPoint x="485" y="580" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="72" value="&lt;b&gt;mssql · TCP 1433&lt;/b&gt;&lt;br&gt;(IP privado, via peering)" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=9;labelBackgroundColor=#f8cecc;" vertex="1" connectable="0" parent="71">
          <mxGeometry x="-0.3" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- NSG CIN -->
        <mxCell id="80" value="&lt;b&gt;nsg-prd-inf-cin-001&lt;/b&gt;&lt;br&gt;associada às 2 subnets" style="aspect=fixed;html=1;points=[];align=center;image;fontSize=9;image=img/lib/azure2/networking/Network_Security_Groups.svg;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1020" y="250" width="50" height="60" as="geometry" />
        </mxCell>
        <mxCell id="81" value="• 80/443 · TCP · origem Internet&lt;br&gt;• 3389 · TCP · origem MEU_IP&lt;br&gt;• 80 · TCP · origem 10.20.0.0/16" style="text;html=1;align=left;verticalAlign=top;fontSize=8;fillColor=#f5f5f5;rounded=1;strokeColor=#CCCCCC;spacingLeft=5;spacingTop=3;" vertex="1" parent="1">
          <mxGeometry x="1000" y="320" width="180" height="55" as="geometry" />
        </mxCell>

        <!-- NSG AES -->
        <mxCell id="82" value="&lt;b&gt;nsg-prd-inf-aes-001&lt;/b&gt;&lt;br&gt;associada à subnet de banco" style="aspect=fixed;html=1;points=[];align=center;image;fontSize=9;image=img/lib/azure2/networking/Network_Security_Groups.svg;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1020" y="690" width="50" height="60" as="geometry" />
        </mxCell>
        <mxCell id="83" value="• 1433 · TCP · origem 10.20.0.0/16 ⚠️&lt;br&gt;• 3389 · TCP · origem MEU_IP&lt;br&gt;⚠️ origem é a VNet do APP (via peering)" style="text;html=1;align=left;verticalAlign=top;fontSize=8;fillColor=#f5f5f5;rounded=1;strokeColor=#CCCCCC;spacingLeft=5;spacingTop=3;" vertex="1" parent="1">
          <mxGeometry x="1000" y="760" width="210" height="55" as="geometry" />
        </mxCell>

        <!-- Admin RDP arrow (dashed) -->
        <mxCell id="90" edge="1" parent="1" source="4" target="30" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#999999;strokeWidth=1;dashed=1;labelBackgroundColor=none;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="774" y="160" />
              <mxPoint x="298" y="160" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="91" value="RDP 3389 (jump host após Fase 8)" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=8;fontStyle=2;labelBackgroundColor=#f5f5f5;" vertex="1" connectable="0" parent="90">
          <mxGeometry x="-0.2" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- Hardening box -->
        <mxCell id="100" value="&lt;b&gt;Fase 8 — Hardening final&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Remove o IP público de vm-bend e vm-data&lt;br&gt;• Admin via jump host: RDP na vm-fend&lt;br&gt;  — salta pelos IPs privados (10.20.2.x / 10.30.1.x)&lt;br&gt;• Só a vm-fend permanece exposta (80/443)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;verticalAlign=top;align=left;spacingLeft=10;spacingTop=5;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1020" y="430" width="250" height="110" as="geometry" />
        </mxCell>

        <!-- Design decisions box -->
        <mxCell id="101" value="&lt;b&gt;Decisões de design&lt;/b&gt;&lt;br&gt;&lt;br&gt;• 2 regiões: limite de 4 vCPU/região (3× B2s = 6 vCPU)&lt;br&gt;  → peering global&lt;br&gt;• 1 NSG por VNet, associada às subnets (não por NIC)&lt;br&gt;  — menos objetos&lt;br&gt;• Sem CORS: /api/* na mesma origem, ARR faz o proxy&lt;br&gt;  reverso p/ :80" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;verticalAlign=top;align=left;spacingLeft=10;spacingTop=5;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1020" y="560" width="270" height="120" as="geometry" />
        </mxCell>

        <!-- Footer -->
        <mxCell id="110" value="&lt;b&gt;Fluxo:&lt;/b&gt; ❶ Torcedor acessa o frontend (80/443) → ❷ ARR reescreve /api/* para o backend (80) → ❸ API consulta o SQL pelo IP privado via peering (1433)&lt;br&gt;Seta tracejada = administração RDP (3389, somente MEU_IP) nos IPs públicos das 3 VMs — substituída pelo acesso via jump host (vm-fend) na Fase 8." style="text;html=1;align=left;verticalAlign=middle;fontSize=9;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="100" y="950" width="850" height="40" as="geometry" />
        </mxCell>

        <!-- Author -->
        <mxCell id="111" value="&lt;b&gt;Silas Machado&lt;/b&gt; · Cloud &amp; Infrastructure Specialist · Copa do Mundo Azure 2026 · TFTEC Prime" style="text;html=1;align=right;verticalAlign=middle;fontSize=9;fillColor=none;strokeColor=none;fontColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="800" y="955" width="400" height="30" as="geometry" />
        </mxCell>

