        <!-- VM Frontend -->
        <mxCell id="30" value="&lt;b&gt;vm-prd-tk-fend-cin-001&lt;/b&gt;&lt;br&gt;FRONTEND · ponto de entrada" style="aspect=fixed;html=1;points=[];align=center;image;fontSize=10;image=img/lib/azure2/compute/Virtual_Machine.svg;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="270" y="270" width="55" height="51" as="geometry" />
        </mxCell>
        <mxCell id="31" value="• Windows Server 2022 · B2als_v2&lt;br&gt;• IIS · 80/443 → sites do React&lt;br&gt;• URL Rewrite + ARR (proxy reverso)&lt;br&gt;• web.config /api/* → backend:80&lt;br&gt;• Certificado HTTPS (Let's Encrypt)&lt;br&gt;• 🌐 IP Público" style="text;html=1;align=left;verticalAlign=top;fontSize=9;fillColor=#d5e8d4;rounded=1;strokeColor=#82b366;spacingLeft=5;spacingRight=5;spacingTop=3;" vertex="1" parent="1">
          <mxGeometry x="150" y="350" width="250" height="100" as="geometry" />
        </mxCell>

        <!-- VM Backend -->
        <mxCell id="32" value="&lt;b&gt;vm-prd-tk-bend-cin-001&lt;/b&gt;&lt;br&gt;BACKEND · API" style="aspect=fixed;html=1;points=[];align=center;image;fontSize=10;image=img/lib/azure2/compute/Virtual_Machine.svg;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="690" y="270" width="55" height="51" as="geometry" />
        </mxCell>
        <mxCell id="33" value="• Windows Server 2022 · B2als_v2&lt;br&gt;• IIS + iisnode · porta 80&lt;br&gt;• Node — fifa2026-api (Express)&lt;br&gt;• .env → IP privado da vm-data (10.30.1.x)&lt;br&gt;• 🔒 Sem IP público (hardening)" style="text;html=1;align=left;verticalAlign=top;fontSize=9;fillColor=#fff2cc;rounded=1;strokeColor=#d6b656;spacingLeft=5;spacingRight=5;spacingTop=3;" vertex="1" parent="1">
          <mxGeometry x="570" y="350" width="260" height="90" as="geometry" />
        </mxCell>

