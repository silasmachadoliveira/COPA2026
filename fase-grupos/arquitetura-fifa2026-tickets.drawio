        <mxCell id="53" value="&lt;b&gt;snet-prd-inf-data-aes-001&lt;/b&gt;  10.30.1.0/24" style="aspect=fixed;html=1;points=[];align=left;image;fontSize=9;image=img/lib/azure2/networking/Subnet.svg;labelPosition=right;verticalLabelPosition=middle;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="260" y="665" width="35" height="21" as="geometry" />
