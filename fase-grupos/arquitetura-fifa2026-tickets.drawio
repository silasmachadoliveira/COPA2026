        <!-- VM Data (SQL) -->
        <mxCell id="60" value="&lt;b&gt;vm-prd-tk-data-aes-001&lt;/b&gt;&lt;br&gt;BANCO · SQL Server 2022" style="aspect=fixed;html=1;points=[];align=center;image;fontSize=10;image=img/lib/azure2/databases/SQL_Server.svg;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="460" y="700" width="50" height="50" as="geometry" />
        </mxCell>
        <mxCell id="61" value="• SQL Server 2022 Developer (imagem pronta)&lt;br&gt;• Windows Server 2022 · B2als_v2&lt;br&gt;• Autenticação SQL · adminsql (wizard)&lt;br&gt;• Database FIFA2026Tickets (bacpac via SSMS)&lt;br&gt;• Aceita 1433 somente de 10.20.0.0/16 (VNet do app)&lt;br&gt;• 3 discos 8GB (Data / Log / TempDB)&lt;br&gt;• 🔒 Sem IP público (hardening)" style="text;html=1;align=left;verticalAlign=top;fontSize=9;fillColor=#f8cecc;rounded=1;strokeColor=#b85450;spacingLeft=5;spacingRight=5;spacingTop=3;" vertex="1" parent="1">
          <mxGeometry x="300" y="780" width="350" height="115" as="geometry" />
        </mxCell>

        <!-- VNet Peering icon -->
        <mxCell id="70" value="&lt;b&gt;VNet Peering Global&lt;/b&gt;&lt;br&gt;IPs privados entre regiões" style="aspect=fixed;html=1;points=[];align=center;image;fontSize=9;image=img/lib/azure2/networking/Virtual_Network_Peering.svg;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="460" y="565" width="50" height="32" as="geometry" />
        </mxCell>

        <!-- Arrow Backend → SQL (via Peering) -->
        <mxCell id="71" edge="1" parent="1" source="32" target="60" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#b85450;strokeWidth=2;labelBackgroundColor=none;">
